<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    
    <!-- Package Metadata -->
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>Lukdrasil.StepUpLogging</PackageId>
    <Version>3.0.0</Version>
    <PackageReleaseNotes>v3.0.0 — BREAKING. See MIGRATION.md. Breaking behavior: (1) `ClientIp` no longer trusts `X-Forwarded-For`; it now comes from `Connection.RemoteIpAddress`. Set the new `TrustForwardedHeaders: true` to restore v2 behavior — but read the security note first: the header is client-supplied and spoofable, and the correct fix is `ForwardedHeadersMiddleware`. (2) A new redacted `ForwardedFor` property appears on request summaries whenever the `X-Forwarded-For` header is present. (3) `MaxBodyCaptureBytes &lt;= 0` now fails at startup via `ValidateOnStart` (`OptionsValidationException`) instead of silently disabling body capture and logging `[UNAVAILABLE]`. (4) Request bodies are now captured for failing (5xx) requests even when step-up has not yet engaged — expect bodies on requests that previously logged none; this fixes the case where the request that TRIGGERED step-up was the only one missing its body. (5) `jti` and `User-Agent` are now passed through the redaction patterns like every other request-derived value. Security / correctness fixes (non-breaking): (6) request bodies are redacted BEFORE truncation, so a secret straddling the `MaxBodyCaptureBytes` boundary can no longer leak its prefix. (7) Redaction patterns compile with `RegexOptions.NonBacktracking` (guaranteed linear time), falling back to `Compiled` for lookaround/backreference patterns; the 100 ms timeout and the fail-closed `[REDACTION-ERROR]` sentinel are unchanged. (8) `OTEL_EXPORTER_OTLP_HEADERS` / `OTEL_RESOURCE_ATTRIBUTES` values are now percent-decoded per the OTel spec, so `Authorization=Basic%20...` reaches the collector intact. (9) Request-summary events are no longer double-exported through the pre-error buffer. (10) `Serilog:MinimumLevel:Override` honours `reloadOnChange` again — the configuration split now wraps the live `IConfiguration` instead of snapshotting it. New options (all backward compatible): `TrustForwardedHeaders` (default false), `MaxContinuousStepUpSeconds` (default 0 = disabled), `StepUpCooldownSeconds` (default 300). Also: one `ApplyRedaction` span per request instead of one per redacted field.</PackageReleaseNotes>
    <Authors>Lukdrasil</Authors>
    <Description>Dynamic step-up logging for ASP.NET Core with Serilog - automatically increase log verbosity when errors occur, with minimal performance overhead. Includes request body capture, sensitive data redaction, and OpenTelemetry metrics.</Description>
    <PackageTags>serilog;logging;aspnetcore;observability;otel;stepup;dynamic-logging;error-logging</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Lukdrasil/StepUpLogging</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Lukdrasil/StepUpLogging</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    
    <!-- Documentation -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>
  
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
        <_Parameter1>Lukdrasil.StepUpLogging.Tests</_Parameter1>
    </AssemblyAttribute>
</ItemGroup>

  <ItemGroup>
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.15.3" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.15.3" />
    <PackageReference Include="Serilog.AspNetCore" Version="10.0.0" />
    <PackageReference Include="Serilog.Sinks.Async" Version="2.1.0" />
    <PackageReference Include="Serilog.Formatting.Compact" Version="3.0.0" />
    <PackageReference Include="Serilog.Enrichers.OpenTelemetry" Version="1.0.1" />
    <PackageReference Include="Serilog.Sinks.OpenTelemetry" Version="4.2.0" />
    <PackageReference Include="Serilog.Exceptions" Version="8.4.0" />
    <PackageReference Include="Serilog.Enrichers.Thread" Version="4.0.0" />
    <PackageReference Include="Serilog.Enrichers.Process" Version="3.0.0" />
    <PackageReference Include="Serilog.Enrichers.Environment" Version="3.0.1" />
    <PackageReference Include="Serilog.Enrichers.CallStack" Version="1.0.358" />
  </ItemGroup>

</Project>
